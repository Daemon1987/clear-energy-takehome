{
  "name": "clear-energy-takehome",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api": "json-server mock-api.json --port 4000",
    "customer": "npm run start --workspace apps/customer",
    "driver": "npm run start --workspace apps/driver",
    "admin": "npm run start --workspace apps/admin-mobile",
    "test": "npm run test --workspace packages/shared",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "json-server": "^0.17.4",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "expo": "^57.0.4"
  }
}
